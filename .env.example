# AI filtering
# Leave empty to run with fallback prioritization only, or use --skip-ai explicitly.
ANTHROPIC_API_KEY=

# Threat intelligence
# Leave empty to skip Shodan enrichment.
SHODAN_API_KEY=

# Jira integration
# Leave empty to skip Jira issue creation.
JIRA_URL=https://your-org.atlassian.net
JIRA_USER=your-email@example.com
JIRA_TOKEN=
JIRA_PROJECT_KEY=SEC
JIRA_TYPE=cloud

# Optional notifications
SLACK_WEBHOOK=

# ZAP / local container configuration
ZAP_API_KEY=changeme
ZAP_PORT=8080
